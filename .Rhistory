rm(list = ls())
library(sf)
library(ggplot2)
gpklink <- "Lima_LISA.gpkg"
map1 <- read_sf(gpklink, layer = "Queen")
ggplot(map1) +
geom_sf(aes(fill = LISA), color = "black", linewidth = 0.1) +
scale_fill_brewer(palette = "PuOr") +
theme_void() +
labs(
title = "Mapa LISA - Queen",
fill = "Clusters"
)
saveRDS(map1gg,file='map1.rds')
saveRDS(map1,file='map1.rds')
View(map1)
View(map1)
View(map1)
map2 <- read_sf(gpklink, layer = "Rook")
map2$LISA <- factor(
map2$LISA,
levels = c(
"1 hotOutlier",
"2 hotSpot",
"3 no_pattern",
"4 coldSpot",
"5 coldOutlier"
)
)
ggplot(map2) +
geom_sf(aes(fill = LISA), color = "black", linewidth = 0.1) +
scale_fill_brewer(palette = "PuOr", drop = FALSE) +
theme_void() +
labs(
title = "Mapa LISA - Rook",
fill = ""
)
saveRDS(map2,file='map2.rds')
map3 <- read_sf(gpklink, layer = "KNN")
map3$LISA <- factor(
map3$LISA,
levels = c(
"1 hotOutlier",
"2 hotSpot",
"3 no_pattern",
"4 coldSpot",
"5 coldOutlier"
)
)
ggplot(map3) +
geom_sf(aes(fill = LISA), color = "black", linewidth = 0.1) +
scale_fill_brewer(palette = "PuOr", drop = FALSE) +
theme_void() +
labs(
title = "Mapa LISA - KNN",
fill = ""
)
saveRDS(map3,file='map3.rds')
map4 <- read_sf(gpklink, layer = "DistanceBand")
map4$LISA <- factor(
map4$LISA,
levels = c(
"1 hotOutlier",
"2 hotSpot",
"3 no_pattern",
"4 coldSpot",
"5 coldOutlier"
)
)
ggplot(map4) +
geom_sf(aes(fill = LISA), color = "black", linewidth = 0.1) +
scale_fill_brewer(palette = "PuOr", drop = FALSE) +
theme_void() +
labs(
title = "Mapa LISA - Distance Band",
fill = ""
)
saveRDS(map4,file='map4.rds')
map1 <- readRDS("~/GitHub/EVAL-FINAL/map1.rds")
View(map1)
map1 <- read_sf(gpklink, layer = "Queen")
ggplot(map1) +
